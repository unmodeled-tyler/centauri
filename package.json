{
  "name": "centauri",
  "version": "0.1.0",
  "description": "Local-first agent development environment with Git source control.",
  "license": "MIT",
  "author": "unmodeled-tyler",
  "type": "module",
  "main": "electron/main.js",
  "bin": {
    "centauri": "./bin/centauri.js"
  },
  "files": [
    "bin",
    "build",
    "dist",
    "electron",
    "scripts/install.sh",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "node ./bin/centauri-dev.js",
    "dev:web": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:cli": "node ./bin/centauri-dev.js",
    "dev:client": "vite",
    "dev:desktop": "npx electron ./electron/main.js",
    "dev:server": "tsx watch server/index.ts",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "build:desktop": "npm run build && electron-builder",
    "build:mac": "npm run build:mac:dir && ./scripts/package-mac-artifacts.sh",
    "build:mac:dir": "npm run build && electron-builder --mac --universal --dir",
    "start": "node ./build/server/server/index.js",
    "start:cli": "node ./bin/centauri.js",
    "preview": "vite preview",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.server.json",
    "prepare": "husky"
  },
  "build": {
    "appId": "com.unmodeledtyler.centauri",
    "productName": "Centauri",
    "artifactName": "${productName}-${version}-${arch}.${ext}",
    "directories": {
      "output": "release"
    },
    "files": [
      "package.json",
      "electron/**",
      "dist/**",
      "build/**",
      "node_modules/**",
      "README.md",
      "LICENSE"
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/node-pty/**"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "identity": null,
      "x64ArchFiles": "Contents/Resources/app.asar.unpacked/node_modules/node-pty/prebuilds/**/*",
      "target": [
        {
          "target": "dir",
          "arch": [
            "universal"
          ]
        }
      ]
    }
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@react-three/postprocessing": "^3.0.4",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "chokidar": "^5.0.0",
    "cors": "^2.8.5",
    "d3-force-3d": "^3.0.6",
    "diff": "^7.0.0",
    "express": "^5.1.0",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.1.0",
    "lucide-react": "^0.488.0",
    "node-pty": "^1.1.0",
    "prism-react-renderer": "^2.4.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.5.0",
    "remark-gfm": "^4.0.1",
    "three": "^0.184.0",
    "ws": "^8.20.1",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.1.0",
    "@types/cors": "^2.8.17",
    "@types/diff": "^7.0.0",
    "@types/express": "^5.0.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.4.0",
    "concurrently": "^9.1.0",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9.24.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "husky": "^9.1.7",
    "tailwindcss": "^4.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.59.3",
    "vite": "^6.3.0"
  }
}
